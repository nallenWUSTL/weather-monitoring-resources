    <!-- Removed Google Fonts for Urbanist to ensure Adobe Acrobat native font compatibility -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Added DataLabels Plugin for Static PDF/PPT Export Readability -->
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>

    <style>
        /* 1. THE SETUP */
        * { box-sizing: border-box; }

        body {
            background-color: #020617; /* slate-950 */
            display: grid;
            gap: 60px; /* Increased external gutter between slides */
            grid-template-columns: 1fr;
            margin: 0;
            min-height: 100vh;
            padding: 60px 40px; /* External gutter preventing screen touch */
            place-items: center;
        }

        .slide-container {
            align-items: flex-start;
            background-color: #0f172a; /* slate-900 */
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            /* Switched to a geometric, Adobe Acrobat-safe font stack */
            font-family: 'Century Gothic', 'Avenir', 'Segoe UI', 'Trebuchet MS', Arial, Helvetica, sans-serif;
            height: 720px;
            justify-content: flex-start;
            overflow: hidden;
            padding: 64px 80px; /* INCREASED INTERNAL GUTTER (Safe Area) */
            position: relative;
            width: 1280px;
            border: 1px solid #1e293b; /* slate-800 */
        }

        .slide-container::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.1) 0%, transparent 40%),
                        radial-gradient(circle at bottom left, rgba(239, 68, 68, 0.05) 0%, transparent 40%);
            z-index: 0;
            pointer-events: none;
        }

        .slide-container > * { position: relative; z-index: 1; }

        /* 2. CONSISTENT TYPOGRAPHY */
        .slide-container h1, .slide-container h2, .slide-container h3, .slide-container h4 {
            color: #f8fafc; /* slate-50 */
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.02em;
        }

        .slide-container h1 { font-size: 72px; line-height: 1.1; font-weight: 900; text-transform: uppercase; }
        .slide-container h1 span.blue { color: #3b82f6; }
        .slide-container h1 span.red { color: #ef4444; }

        .slide-container .slide-title {
            font-size: 44px; /* Slightly scaled to match new grid */
            font-weight: 900;
            margin-bottom: 32px;
            text-align: left;
            width: 100%;
            color: #f8fafc;
            text-transform: uppercase;
            letter-spacing: 0.02em;
            border-bottom: 2px solid #1e293b;
            padding-bottom: 15px;
        }

        .slide-container .subtitle {
            font-size: 24px;
            color: #3b82f6;
            margin: 20px auto;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 700;
        }

        .slide-container .content-area {
            align-items: flex-start;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            width: 100%;
            height: 100%;
            max-height: 100%;
            position: relative;
        }

        /* 3. LAYOUT DEFINITIONS */
        .title-layout { text-align: center; align-self: center; margin-top: auto; margin-bottom: auto; width: 100%;}
        
        .title-layout .date-badge {
            display: inline-block;
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid rgba(59, 130, 246, 0.5);
            color: #60a5fa;
            padding: 8px 24px;
            border-radius: 999px;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 30px;
        }

        /* FORECAST GRID LAYOUT */
        .forecast-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 32px; /* Compressed to fit safe area */
            width: 100%; 
            height: 100%; 
        }
        
        .forecast-card { 
            background: #1e293b; 
            border-radius: 20px; 
            border: 1px solid #334155; 
            padding: 32px; /* Reduced internal padding to save space */
            display: flex; 
            flex-direction: column; 
            box-shadow: inset 0 2px 10px rgba(255,255,255,0.02);
        }
        
        .forecast-card .period-title { 
            font-size: 28px; 
            font-weight: 900; 
            color: #3b82f6; 
            margin-bottom: 20px; 
            text-transform: uppercase; 
        }

        .forecast-metrics { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 12px; 
            margin-bottom: 24px; 
        }

        .metric { 
            background: #0f172a; 
            padding: 12px; 
            border-radius: 12px; 
            border: 1px solid #0f172a; 
            text-align: center; 
        }

        .metric-value { font-size: 28px; font-weight: 900; color: #f8fafc; line-height: 1; }
        .metric-value.red { color: #f87171; }
        .metric-value.blue { color: #60a5fa; }
        
        .metric-label { 
            font-size: 11px; 
            font-weight: 900; 
            color: #64748b; 
            text-transform: uppercase; 
            margin-top: 8px; 
            letter-spacing: 0.05em;
        }

        .forecast-short { 
            font-size: 22px; 
            font-weight: 900; 
            color: #f1f5f9; 
            margin-bottom: 12px;
            line-height: 1.3;
        }

        .forecast-desc { 
            color: #94a3b8; 
            font-size: 16px; 
            line-height: 1.5; 
            font-weight: 500;
        }

        /* HOUR-BY-HOUR TABLE & BADGES */
        .hour-table { width: 100%; border-collapse: separate; border-spacing: 0 6px; }
        .hour-table th { color: #64748b; font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; padding: 0 12px 10px 12px; border-bottom: 2px solid #334155; }
        .hour-table th:first-child { text-align: left; }
        .hour-table td { background: #1e293b; padding: 12px 16px; text-align: center; }
        .hour-table tr td:first-child { border-radius: 12px 0 0 12px; border-left: 4px solid #334155; text-align: left; font-weight: 900; color: #f8fafc; font-size: 18px;}
        .hour-table tr td:last-child { border-radius: 0 12px 12px 0; }
        
        .badge { display: inline-block; padding: 6px 12px; border-radius: 8px; font-weight: 900; font-size: 16px; color: #f8fafc; min-width: 60px; }
        .badge-normal { background: #0f172a; color: #94a3b8; border: 1px solid #334155; }
        .badge-warm { background: #ef4444; color: #fff; } /* Temp > 75F */
        .badge-cool { background: #3b82f6; color: #fff; } /* Temp < 32F */
        .badge-precip-high { background: #0ea5e9; color: #fff; } /* Precip > 50% */
        .badge-precip-ext { background: #2563eb; color: #fff; } /* Precip > 80% */
        .badge-rh-high { background: #8b5cf6; color: #fff; } /* Humidity > 80% */
        .badge-wind-high { background: #f59e0b; color: #fff; } /* Winds/Gusts > 15mph */
        .badge-wind-ext { background: #ef4444; color: #fff; } /* Gusts > 30mph */

        .outlier-legend {
            margin-top: auto; 
            font-size: 12px; 
            color: #64748b; 
            font-weight: 700; 
            text-transform: uppercase; 
            letter-spacing: 0.05em; 
            background: #0f172a; 
            padding: 12px 20px; 
            border-radius: 12px; 
            border: 1px solid #1e293b; 
            width: 100%; 
            display: flex; 
            justify-content: space-between;
        }

        /* Bullet Points (Exec Summary) - Judiciously sized to prevent overflow */
        .bullet-list { width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center;}
        .bullet-list ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px;}
        .bullet-list li {
            background: #1e293b;
            padding: 16px 24px 16px 72px;
            border-radius: 16px;
            position: relative;
            color: #cbd5e1;
            border: 1px solid #334155;
            font-size: 16px;
            line-height: 1.5;
        }
        .bullet-list i {
            color: #3b82f6;
            font-size: 20px;
            left: 24px;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
        }
        .bullet-list li strong { color: #f8fafc; font-weight: 900; font-size: 18px; display: block; margin-bottom: 2px;}

        /* --- CHART STYLING --- */
        .chart-controls { display: flex; gap: 12px; margin-bottom: 24px; width: 100%; justify-content: center; }
        .chart-btn { background: #0f172a; color: #64748b; border: 1px solid #334155; padding: 10px 24px; border-radius: 999px; cursor: pointer; font-weight: 900; font-family: inherit; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.2s; }
        .chart-btn:hover { background: #1e293b; color: #cbd5e1; }
        .chart-btn.active { background: rgba(59, 130, 246, 0.2); color: #60a5fa; border-color: rgba(59, 130, 246, 0.5); }
        .chart-wrapper { flex-grow: 1; width: 100%; background: #1e293b; border-radius: 20px; border: 1px solid #334155; padding: 24px; position: relative; box-shadow: inset 0 2px 10px rgba(255,255,255,0.02); min-height: 0; }

        /* --- PDF PRINT STYLING --- */
        @media print {
            @page {
                size: 1280px 720px; /* Force page size to exactly match the slide */
                margin: 0; /* Remove browser margins */
            }
            body {
                background-color: #020617;
                display: block; /* Remove grid to prevent layout distortion */
                gap: 0;
                margin: 0;
                padding: 0;
                -webkit-print-color-adjust: exact; /* Force render background colors */
                print-color-adjust: exact;
            }
            .slide-container {
                border: none;
                border-radius: 0; /* Sharp corners for printing */
                box-shadow: none;
                height: 720px;
                width: 1280px;
                margin: 0;
                page-break-after: always; /* Force page breaks */
                break-after: page;
                page-break-inside: avoid;
                break-inside: avoid;
            }
            /* Remove the page break on the last slide to prevent a blank final page */
            .slide-container:last-child {
                page-break-after: auto;
                break-after: auto;
            }
        }

    </style>
</head>
