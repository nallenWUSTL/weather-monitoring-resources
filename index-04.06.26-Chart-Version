<script>
    // --- Configuration ---
    const LAT = 38.6482;
    const LON = -90.3056;
    const HEADERS = { "User-Agent": "WashUEmergencyOps/1.0 (nickolas@wustl.edu)" };

    // Register ChartDataLabels plugin globally so it's available for all our charts
    Chart.register(ChartDataLabels);

    // --- Chart State ---
    let globalHourlyPeriods = [];
    let chartInstances = {};

    // --- Core API Retrieval ---
    async function fetchWeatherOpsData() {
        try {
            // Update Timestamp
            document.getElementById('generated-time').innerText = `Generated: ${new Date().toLocaleString()}`;

            // 1. Get Point Metadata
            const pointRes = await fetch(`https://api.weather.gov/points/${LAT},${LON}`, {headers: HEADERS});
            const pointData = await pointRes.json();
            const forecastUrl = pointData.properties.forecast;
            const hourlyUrl = pointData.properties.forecastHourly;

            // 2. Execute Data Calls in Parallel
            const [forecastRes, hourlyRes, alertsRes] = await Promise.all([
                fetch(forecastUrl, {headers: HEADERS}),
                fetch(hourlyUrl, {headers: HEADERS}),
                fetch(`https://api.weather.gov/alerts/active?point=${LAT},${LON}`, {headers: HEADERS})
            ]);

            const forecastData = await forecastRes.json();
            const hourlyData = await hourlyRes.json();
            const alertsData = await alertsRes.json();

            globalHourlyPeriods = hourlyData.properties.periods;

            // 3. Populate Dashboard
            populateAlerts(alertsData.features || []);
            populateForecast(forecastData.properties.periods);
            populateHourly(hourlyData.properties.periods);
            populateExecutiveSummary(forecastData.properties.periods, alertsData.features || []);
            initCharts();

        } catch (error) {
            console.error("Failed to fetch NWS Data:", error);
            document.getElementById('generated-time').innerText = "ERROR: Failed to establish live connection to NWS API.";
            document.getElementById('generated-time').style.color = "#ef4444";
        }
    }

    // --- Helper Functions ---
    function extractMaxWind(windStr) {
        const nums = windStr.match(/\d+/g);
        return nums ? Math.max(...nums.map(Number)) : 0;
    }

    function getPrecip(period) {
        return period.probabilityOfPrecipitation && period.probabilityOfPrecipitation.value !== null 
            ? period.probabilityOfPrecipitation.value 
            : 0;
    }

    // --- Populators ---
    function populateAlerts(alerts) {
        const container = document.getElementById('alerts-container');
        if (alerts.length === 0) {
            container.innerHTML = `
                <div style="display: flex; align-items: center; justify-content: center; height: 100%; width: 100%; flex-direction: column; text-align: center; gap: 20px;">
                    <i class="fa-solid fa-circle-check" style="color: #22c55e; font-size: 80px;"></i>
                    <h3 style="color: #22c55e; font-size: 36px; margin: 0; text-transform: uppercase;">All-Clear</h3>
                    <p style="color: #94a3b8; font-size: 24px;">There are no active NWS hazards or alerts currently issued for the region.</p>
                </div>`;
            return;
        }

        let tableHtml = `
            <table class="alerts-table" style="width: 100%; border-collapse: separate; border-spacing: 0 15px;">
                <thead>
                    <tr>
                        <th style="color: #64748b; font-size: 16px; text-transform: uppercase; letter-spacing: 0.1em; text-align: left; padding: 0 24px 10px 24px; border-bottom: 2px solid #334155; width: 35%;">Event / Severity</th>
                        <th style="color: #64748b; font-size: 16px; text-transform: uppercase; letter-spacing: 0.1em; text-align: left; padding: 0 24px 10px 24px; border-bottom: 2px solid #334155; width: 65%;">Headline Details</th>
                    </tr>
                </thead>
                <tbody>`;
        
        // Take top 3 alerts to prevent overflow
        alerts.slice(0, 3).forEach(alert => {
            const props = alert.properties;
            const isSevere = props.severity === 'Severe' || props.severity === 'Extreme';
            const color = isSevere ? '#ef4444' : '#f59e0b';
            const icon = isSevere ? 'fa-triangle-exclamation' : 'fa-cloud-bolt';
            
            tableHtml += `
                <tr>
                    <td style="background: #1e293b; padding: 24px; border-radius: 16px 0 0 16px; border-left: 4px solid ${color};">
                        <div style="color: ${color}; font-weight: 900; font-size: 24px; text-transform: uppercase;"><i class="fa-solid ${icon}"></i> ${props.event}</div>
                        <div style="color: #94a3b8; font-size: 14px; margin-top: 8px; font-weight: 700; text-transform: uppercase;">Severity: ${props.severity}</div>
                    </td>
                    <td style="background: #1e293b; padding: 24px; border-radius: 0 16px 16px 0;">
                        <div style="color: #cbd5e1; font-size: 18px; line-height: 1.5; font-weight: 500;">${props.headline || props.description.substring(0, 150) + '...'}</div>
                    </td>
                </tr>`;
        });
        tableHtml += `</tbody></table>`;
        container.innerHTML = tableHtml;
    }

    function populateForecast(periods) {
        for (let i = 0; i < 6; i++) {
            if (!periods[i]) break;
            const p = periods[i];
            const pNum = i + 1;
            
            document.getElementById(`p${pNum}-title`).innerText = p.name;
            
            const tempEl = document.getElementById(`p${pNum}-temp`);
            tempEl.innerText = `${p.temperature}°F`;
            if (p.temperature >= 80) tempEl.className = "metric-value red";
            else if (p.temperature <= 40) tempEl.className = "metric-value blue";
            else tempEl.className = "metric-value";

            const popEl = document.getElementById(`p${pNum}-pop`);
            const pop = getPrecip(p);
            popEl.innerText = `${pop}%`;
            if (pop >= 50) popEl.className = "metric-value blue";
            else popEl.className = "metric-value";

            document.getElementById(`p${pNum}-wind`).innerHTML = `${extractMaxWind(p.windSpeed)} <span style="font-size: 14px; color:#64748b;">mph</span>`;
            document.getElementById(`p${pNum}-short`).innerText = p.shortForecast;
            document.getElementById(`p${pNum}-desc`).innerText = p.detailedForecast;
        }
    }

    function populateHourly(hourlyPeriods) {
        const tbody = document.getElementById('hourly-table-body');
        let rows = '';

        // Slice next 6 hours
        hourlyPeriods.slice(0, 6).forEach(p => {
            const date = new Date(p.startTime);
            const timeStr = date.toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit', timeZoneName: 'short'}).replace(/C[DS]T/, 'CST');
            
            const temp = p.temperature;
            const precip = getPrecip(p);
            const rh = p.relativeHumidity ? p.relativeHumidity.value : 0;
            const wind = extractMaxWind(p.windSpeed);
            const gust = extractMaxWind(p.windGust || p.windSpeed);

            // Conditional formatting based on March Outliers
            const tempBadge = temp > 75 ? 'badge-warm' : (temp < 32 ? 'badge-cool' : 'badge-normal');
            const precipBadge = precip >= 80 ? 'badge-precip-ext' : (precip >= 50 ? 'badge-precip-high' : 'badge-normal');
            const rhBadge = rh >= 80 ? 'badge-rh-high' : 'badge-normal';
            const windBadge = wind >= 30 ? 'badge-wind-ext' : (wind >= 15 ? 'badge-wind-high' : 'badge-normal');
            const gustBadge = gust >= 35 ? 'badge-wind-ext' : (gust >= 20 ? 'badge-wind-high' : 'badge-normal');

            rows += `
                <tr>
                    <td>${timeStr}</td>
                    <td><span class="badge ${tempBadge}">${temp}°F</span></td>
                    <td><span class="badge ${precipBadge}">${precip}%</span></td>
                    <td><span class="badge ${rhBadge}">${rh}%</span></td>
                    <td><span class="badge ${windBadge}">${wind} mph</span></td>
                    <td><span class="badge ${gustBadge}">${gust} mph</span></td>
                </tr>
            `;
        });
        tbody.innerHTML = rows;
    }

    function populateExecutiveSummary(periods, alerts) {
        // 1. Alerts
        if (alerts.length > 0) {
            document.getElementById('exec-alert-icon').className = "fa-solid fa-triangle-exclamation";
            document.getElementById('exec-alert-icon').style.color = "#ef4444";
            document.getElementById('exec-alert-title').innerText = "Active Hazard";
            document.getElementById('exec-alert-title').style.color = "#ef4444";
            document.getElementById('exec-alert-text').innerText = `There are ${alerts.length} active NWS alert(s) currently issued for the region. Immediate attention to safety protocols is recommended.`;
        }

        // 2. Precip & Temp/Wind logic over the 48 hour (6 period) window
        const next48 = periods.slice(0, 6);
        let maxTempPeriod = next48[0];
        let maxWindPeriod = next48[0];
        let maxPrecipPeriod = next48[0];

        next48.forEach(p => {
            if (p.temperature > maxTempPeriod.temperature) maxTempPeriod = p;
            if (extractMaxWind(p.windSpeed) > extractMaxWind(maxWindPeriod.windSpeed)) maxWindPeriod = p;
            if (getPrecip(p) > getPrecip(maxPrecipPeriod)) maxPrecipPeriod = p;
        });

        // Precip Update
        const maxPop = getPrecip(maxPrecipPeriod);
        if (maxPop >= 50) {
            document.getElementById('exec-precip-text').innerText = `Elevated precipitation risk detected. A peak probability of ${maxPop}% is forecasted during the '${maxPrecipPeriod.name}' operational period.`;
        } else {
            document.getElementById('exec-precip-text').innerText = `Low precipitation risk over the next 48 hours. Peak probability is currently forecasted at ${maxPop}%.`;
        }

        // Temp & Wind Update
        let tempText = `Temperatures will peak at ${maxTempPeriod.temperature}°F on ${maxTempPeriod.name}. `;
        const maxWind = extractMaxWind(maxWindPeriod.windSpeed);
        if (maxWind >= 15) {
            tempText += `Notable wind hazards detected, with sustained speeds reaching ${maxWindPeriod.windSpeed} during the '${maxWindPeriod.name}' period.`;
        } else {
            tempText += `Wind speeds are expected to remain manageable (under 15 mph).`;
        }
        document.getElementById('exec-temp-text').innerText = tempText;
    }

    // --- Chart Logic ---
    function initCharts() {
        if (Object.keys(chartInstances).length === 0) {
            // Temperature Trends
            createCombinedChart(12, 'chart-12h');
            createCombinedChart(24, 'chart-24h');
            createCombinedChart(72, 'chart-72h');
            createCombinedChart(120, 'chart-120h');
            
            // Precipitation Trends
            createPrecipChart(12, 'chart-p-12h');
            createPrecipChart(24, 'chart-p-24h');
            createPrecipChart(72, 'chart-p-72h');
            createPrecipChart(120, 'chart-p-120h');
        } else {
            updateCombinedChart('chart-12h', 12);
            updateCombinedChart('chart-24h', 24);
            updateCombinedChart('chart-72h', 72);
            updateCombinedChart('chart-120h', 120);
            
            updatePrecipChart('chart-p-12h', 12);
            updatePrecipChart('chart-p-24h', 24);
            updatePrecipChart('chart-p-72h', 72);
            updatePrecipChart('chart-p-120h', 120);
        }
    }

    // PDF Export format helper - ensures short strings like "Mon 2PM" that don't collide
    function getExportSafeTimeLabel(startTime, hours) {
        const d = new Date(startTime);
        const timeStr = d.toLocaleTimeString('en-US', {hour: 'numeric', hour12: true}).replace(' ', ''); // e.g., "2PM"
        if (hours <= 24) return timeStr;
        const dayStr = d.toLocaleDateString('en-US', {weekday: 'short'}); // e.g., "Mon"
        return `${dayStr} ${timeStr}`;
    }

    // 1. Temperature Chart Configuration
    function getCombinedChartData(hours) {
        const dataSlice = globalHourlyPeriods.slice(0, hours);
        const labels = dataSlice.map(p => getExportSafeTimeLabel(p.startTime, hours));
        const temps = dataSlice.map(p => p.temperature);
        
        const avgValue = temps.reduce((a, b) => a + b, 0) / temps.length;
        const maxValue = Math.max(...temps);
        const minValue = Math.min(...temps);

        const avgLine = Array(temps.length).fill(avgValue);
        const maxLine = Array(temps.length).fill(maxValue);
        const minLine = Array(temps.length).fill(minValue);

        return {
            labels,
            datasets: [
                {
                    label: 'Hourly Temp (°F)',
                    data: temps,
                    borderColor: '#94a3b8',
                    backgroundColor: 'rgba(148, 163, 184, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 0,
                    datalabels: {
                        display: function(context) {
                            if (hours > 24) return context.dataIndex % 6 === 0; // Prevent collision on 3-day/5-day
                            return true;
                        },
                        align: 'top',
                        anchor: 'center',
                        offset: 8,
                        formatter: value => Math.round(value) + '°'
                    }
                },
                {
                    label: `Average (${avgValue.toFixed(1)}°F)`,
                    data: avgLine,
                    borderColor: '#10b981',
                    borderWidth: 2,
                    borderDash: [5, 5],
                    pointRadius: 0,
                    fill: false,
                    datalabels: { display: false } // Hide labels for static reference line
                },
                {
                    label: `Maximum (${maxValue}°F)`,
                    data: maxLine,
                    borderColor: '#ef4444',
                    borderWidth: 2,
                    borderDash: [5, 5],
                    pointRadius: 0,
                    fill: false,
                    datalabels: { display: false } // Hide labels for static reference line
                },
                {
                    label: `Minimum (${minValue}°F)`,
                    data: minLine,
                    borderColor: '#3b82f6',
                    borderWidth: 2,
                    borderDash: [5, 5],
                    pointRadius: 0,
                    fill: false,
                    datalabels: { display: false } // Hide labels for static reference line
                }
            ]
        };
    }

    function createCombinedChart(hours, elementId) {
        const ctx = document.getElementById(elementId).getContext('2d');
        const chartData = getCombinedChartData(hours);

        chartInstances[elementId] = new Chart(ctx, {
            type: 'line',
            data: chartData,
            options: {
                animation: false, // CRITICAL FOR PRINT-TO-PDF SCRIPTS
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: { top: 25, right: 20 } }, // Space for data labels to prevent clipping
                plugins: {
                    legend: { labels: { color: '#f8fafc', font: { family: 'Century Gothic', weight: 'bold', size: 14 } } },
                    tooltip: { mode: 'index', intersect: false },
                    datalabels: {
                        color: '#f8fafc',
                        font: { family: 'Century Gothic', weight: 'bold', size: 12 }
                    }
                },
                scales: {
                    x: { 
                        grid: { color: '#334155' }, 
                        ticks: { 
                            color: '#94a3b8', 
                            font: { family: 'Century Gothic', size: 12 },
                            maxRotation: 45, 
                            minRotation: 45,
                            autoSkip: true,
                            maxTicksLimit: 24 // Keep PPT axes clean
                        } 
                    },
                    y: { 
                        grid: { color: '#334155' }, 
                        ticks: { color: '#94a3b8', font: { family: 'Century Gothic', size: 12 } } 
                    }
                }
            }
        });
    }

    function updateCombinedChart(elementId, hours) {
        if (chartInstances[elementId] && globalHourlyPeriods.length > 0) {
            chartInstances[elementId].data = getCombinedChartData(hours);
            chartInstances[elementId].update();
        }
    }

    // 2. Precipitation Chart Configuration
    function getPrecipChartData(hours) {
        const dataSlice = globalHourlyPeriods.slice(0, hours);
        const labels = dataSlice.map(p => getExportSafeTimeLabel(p.startTime, hours));

        // Safe extractions for dynamic hourly API payload combinations
        const pop = dataSlice.map(p => p.probabilityOfPrecipitation?.value || 0);
        
        const qpf = dataSlice.map(p => {
            if (p.precipitationAmount) return p.precipitationAmount.value || 0;
            return 0;
        });

        const thunder = dataSlice.map(p => {
            if (p.probabilityOfThunder) return p.probabilityOfThunder.value || 0;
            if (p.shortForecast && p.shortForecast.toLowerCase().includes('thunder')) return 40; // mock baseline if text confirms thunder
            return 0;
        });

        return {
            labels,
            datasets: [
                {
                    label: 'PoP (%)',
                    data: pop,
                    backgroundColor: 'rgba(59, 130, 246, 0.4)',
                    borderColor: '#3b82f6',
                    borderWidth: 1,
                    type: 'bar',
                    yAxisID: 'y', // Uses percentage axis
                    datalabels: {
                        display: function(context) {
                            const val = context.dataset.data[context.dataIndex];
                            if (val === 0) return false; // Skip 0% to prevent clutter
                            if (hours > 24) return context.dataIndex % 6 === 0;
                            return true;
                        },
                        align: 'top',
                        anchor: 'end',
                        color: '#60a5fa',
                        formatter: value => Math.round(value) + '%'
                    }
                },
                {
                    label: 'Thunder Risk (%)',
                    data: thunder,
                    borderColor: '#f59e0b',
                    borderWidth: 2,
                    borderDash: [5, 5],
                    type: 'line',
                    pointRadius: 0,
                    yAxisID: 'y', // Uses percentage axis
                    datalabels: { display: false } // Prevent clutter with line labels overlapping bars
                },
                {
                    label: 'Precip Amount (in)',
                    data: qpf,
                    backgroundColor: 'rgba(14, 165, 233, 0.6)',
                    borderColor: '#0ea5e9',
                    borderWidth: 1,
                    type: 'bar',
                    yAxisID: 'y1', // Uses independent amount axis
                    datalabels: {
                        display: function(context) {
                            const val = context.dataset.data[context.dataIndex];
                            if (val === 0) return false; // Skip 0" to prevent clutter
                            if (hours > 24) return context.dataIndex % 6 === 0;
                            return true;
                        },
                        align: 'top',
                        anchor: 'end',
                        color: '#38bdf8',
                        formatter: value => value.toFixed(2) + '"'
                    }
                }
            ]
        };
    }

    function createPrecipChart(hours, elementId) {
        const ctx = document.getElementById(elementId).getContext('2d');
        const chartData = getPrecipChartData(hours);

        chartInstances[elementId] = new Chart(ctx, {
            type: 'line',
            data: chartData,
            options: {
                animation: false, // CRITICAL FOR PRINT-TO-PDF SCRIPTS
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: { top: 30, right: 20 } },
                plugins: {
                    legend: { labels: { color: '#f8fafc', font: { family: 'Century Gothic', weight: 'bold', size: 14 } } },
                    tooltip: { mode: 'index', intersect: false },
                    datalabels: { font: { family: 'Century Gothic', weight: 'bold', size: 11 } }
                },
                scales: {
                    x: { 
                        grid: { color: '#334155' }, 
                        ticks: { 
                            color: '#94a3b8', 
                            font: { family: 'Century Gothic', size: 12 },
                            maxRotation: 45, 
                            minRotation: 45,
                            autoSkip: true,
                            maxTicksLimit: 24 
                        } 
                    },
                    y: { // Percentage Axis
                        type: 'linear',
                        display: true,
                        position: 'left',
                        min: 0,
                        max: 100,
                        title: { display: true, text: 'Probability (%)', color: '#94a3b8', font: {family: 'Century Gothic', size: 14} },
                        grid: { color: '#334155' }, 
                        ticks: { color: '#94a3b8', font: { family: 'Century Gothic', size: 12 } } 
                    },
                    y1: { // Amount Axis
                        type: 'linear',
                        display: true,
                        position: 'right',
                        min: 0,
                        suggestedMax: 0.5, // Ensure small bars don't hit the top of the graph
                        title: { display: true, text: 'Amount (in)', color: '#0ea5e9', font: {family: 'Century Gothic', size: 14} },
                        grid: { drawOnChartArea: false },
                        ticks: { color: '#0ea5e9', font: { family: 'Century Gothic', size: 12 } }
                    }
                }
            }
        });
    }

    function updatePrecipChart(elementId, hours) {
        if (chartInstances[elementId] && globalHourlyPeriods.length > 0) {
            chartInstances[elementId].data = getPrecipChartData(hours);
            chartInstances[elementId].update();
        }
    }

    // Initialize
    window.onload = () => {
        fetchWeatherOpsData();
        // Set auto-refresh timer for 5 minutes (300,000 milliseconds)
        setInterval(fetchWeatherOpsData, 300000); 
    };

</script>
</body>
</html>
